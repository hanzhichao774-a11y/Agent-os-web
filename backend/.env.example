# =============================
# Agent OS Backend 配置
# =============================

# --- LLM 提供商（选择其一）---

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic（可选）
# ANTHROPIC_API_KEY=sk-ant-...

# --- 模型配置 ---
# 支持的 MODEL_PROVIDER: openai | anthropic
MODEL_PROVIDER=openai

# OpenAI 可选: gpt-4o | gpt-4o-mini | gpt-4-turbo
# Anthropic 可选: claude-sonnet-4-6 | claude-3-5-sonnet-20241022
MODEL_ID=gpt-4o-mini
