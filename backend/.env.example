# =============================
# Agent OS Backend 配置
# =============================

# --- LLM 提供商（选择其一）---

# OpenAI
# OPENAI_API_KEY=sk-...

# MiniMax
# MINIMAX_API_KEY=sk-...

# Kimi (Moonshot)
# KIMI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- 模型配置 ---
# 支持的 MODEL_PROVIDER: openai | minimax | kimi | anthropic
MODEL_PROVIDER=openai

# OpenAI 可选: gpt-4o | gpt-4o-mini | gpt-4-turbo
# MiniMax 可选: MiniMax-M2.7 | MiniMax-M2.7-highspeed | MiniMax-M2.5
# Kimi 可选: kimi-2.6 | moonshot-v1-128k | moonshot-v1-32k
# Anthropic 可选: claude-sonnet-4-6 | claude-3-5-sonnet-20241022
MODEL_ID=gpt-4o-mini
