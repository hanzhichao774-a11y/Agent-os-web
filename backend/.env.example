# =============================
# Agent OS Backend 配置
# =============================

# --- LLM 提供商（选择其一）---

# OpenAI
# OPENAI_API_KEY=sk-...

# MiniMax
# MINIMAX_API_KEY=sk-...

# Kimi (Moonshot)
# KIMI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- 模型配置 ---
# 支持的 MODEL_PROVIDER: openai | minimax | kimi | anthropic | custom
MODEL_PROVIDER=openai
MODEL_ID=gpt-4o-mini

# --- 自定义/私有化部署（千问等 OpenAI 兼容服务）---
# MODEL_PROVIDER=custom
# CUSTOM_API_KEY=sk-xxx
# CUSTOM_BASE_URL=http://your-host:8080/v1
# CUSTOM_MODEL_ID=qwen-plus

# --- Embedding 模型（必须配置，否则知识库功能不可用）---
# EMBEDDING_MODEL_ID=openai/text-embedding-3-small
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_DIMENSIONS=512

# --- Reranker 模型（可选，留空则不启用）---
# RERANKER_MODEL_ID=cohere/rerank-v3.5
# RERANKER_API_KEY=sk-xxx
# RERANKER_BASE_URL=https://openrouter.ai/api/v1
# RERANKER_TOP_N=5

# --- 向量数据库（PostgreSQL + pgvector）---
PGVECTOR_DB_URL=postgresql+psycopg://ai:ai@pgvector:5532/ai
